# Copy this file to .env and adjust paths for your machine.

# macOS Steam default:
ADOFAI_DIR="$HOME/Library/Application Support/Steam/steamapps/common/A Dance of Fire and Ice"

# Optional overrides. Leave commented unless your setup differs.
# ADOFAI_MODS_DIR="$ADOFAI_DIR/Mods"
# ADOFAI_MANAGED="$ADOFAI_DIR/ADanceOfFireAndIce.app/Contents/Resources/Data/Managed"

# .NET SDK location.
DOTNET_ROOT="$HOME/.dotnet"
# DOTNET_EXE="$DOTNET_ROOT/dotnet"

# Optional dependency overrides.
# UNITY_MOD_MANAGER_DLL="$ADOFAI_MANAGED/UnityModManager/UnityModManager.dll"
# HARMONY_DLL="$ADOFAI_MANAGED/UnityModManager/0Harmony.dll"
# JALIB_DLL="$ADOFAI_MODS_DIR/JALib/JALib.dll"
# JAMOD_BOOTSTRAP_DLL="$ADOFAI_MODS_DIR/JALib/JAMod.Bootstrap.dll"
# TUFHELPER_DLL="$ADOFAI_MODS_DIR/TUFHelper/TUFHelper.dll"
# ADOFAI_IPC_DLL="$ADOFAI_MODS_DIR/AdofaiIpc/AdofaiIpc.dll"
# ADOFIA_IPC_DLL="$ADOFAI_MODS_DIR/AdofaiIpc/AdofaiIpc.dll"

# Optional native SQLite override.
# macOS uses /usr/lib/libsqlite3.dylib by default, so this is usually unnecessary.
# SQLITE_NATIVE_LIBRARY="/path/to/libsqlite3-or-e_sqlite3"

# Optional output/install overrides.
# TUFREPLAY_BUILD_DIR="./build/TUFReplay"
# TUFREPLAY_INSTALL_DIR="$ADOFAI_MODS_DIR/TUFReplay"
